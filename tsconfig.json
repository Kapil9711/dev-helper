{
  "compilerOptions": {
    "target": "ES2022",

    "module": "NodeNext",

    "moduleResolution": "NodeNext",

    "rootDir": ".",

    "outDir": "./dist",

    "strict": true,
    "types": ["node"],

    "esModuleInterop": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "declaration": true
  },

  "include": ["src", "bin"]
}
