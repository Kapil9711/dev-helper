{
  "compilerOptions": {
    "target": "ES2022",

    "module": "NodeNext",

    "moduleResolution": "NodeNext",

    "outDir": "./dist",

    "rootDir": "./src",

    "strict": true,
    "types": ["node"],

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "declaration": true,

    "sourceMap": true,

    "rewriteRelativeImportExtensions": true,

    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
